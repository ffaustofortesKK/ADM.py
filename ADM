import streamlit as st
from supabase import create_client
from datetime import datetime, timezone

# Configuração
url = st.secrets["URL_SUPABASE"]
key = st.secrets["KEY_SUPABASE"]
supabase = create_client(url, key)

st.set_page_config(page_title="Painel de Administração", layout="wide")
st.title("🛡️ Painel de Controle")

# --- LOGIN ---
if "logado" not in st.session_state: st.session_state["logado"] = False
if not st.session_state["logado"]:
    senha = st.text_input("Senha:", type="password")
    if st.button("Entrar") and senha == "1234":
        st.session_state["logado"] = True
        st.rerun()
    st.stop()

# --- SEÇÃO 2: FILA DE PRESTADORES ---
st.subheader("🎤 Fila de Prestadores")
if st.button("🔄 Atualizar Fila"):
    st.rerun()

try:
    # Busca todos os prestadores
    prestadores = supabase.table("prestadores").select("*").execute().data
    
    if prestadores:
        header1, header2, header3, header4 = st.columns([2, 2, 1, 1])
        header1.write("**Prestador**")
        header2.write("**Ref.**")
        header3.write("**Status**")
        header4.write("**Ação**")

        for p in prestadores:
            col1, col2, col3, col4 = st.columns([2, 2, 1, 1])
            
            # Tenta ler as colunas 'nome' e 'sobrenome' em minúsculas
            # Se não encontrar, tenta ler 'slug_unico' para não deixar vazio
            nome_valor = p.get('nome') or p.get('Nome') or ""
            sobrenome_valor = p.get('sobrenome') or p.get('Sobrenome') or ""
            
            # Concatena o nome completo
            nome_completo = f"{nome_valor} {sobrenome_valor}".strip()
            
            # Se ainda assim estiver vazio, usa o slug_unico como último recurso
            if not nome_completo or nome_completo == "":
                nome_completo = p.get('slug_unico', 'Sem Nome')
            
            col1.write(f"**{nome_completo}**")
            
            # Exibe a referência de pagamento
            col2.write(str(p.get('referencia_pagamento', 'N/A')))
            
            status = p.get('status_pagamento', False)
            
            if status:
                col3.write("✅ SIM")
                # Cálculo de tempo (exemplo simplificado)
                inicio_str = p.get('inicio_servico')
                if inicio_str:
                    # Ajuste conforme necessário para o seu formato de data
                    col4.write("⏳ Em uso") 
            else:
                col3.write("❌ NÃO")
                if col4.button("Pagar", key=f"btn_{p.get('id')}"):
                    # Lógica de atualização aqui
                    st.rerun()
    else:
        st.write("Nenhum prestador cadastrado.")
except Exception as e:
    st.error(f"Erro ao buscar prestadores: {e}")
